# Server configuration (copy to .env or set in the environment)
PORT=3001
HOST=0.0.0.0

# Where the DuckDB file, SQLite metadata DB, and staged uploads live.
DATA_DIR=./data
STAGING_DIR=./data/staging

# Max rows any single metric query may return.
MAX_ROWS=50000

# Number of reusable DuckDB read connections.
READ_POOL_SIZE=4

# Per-query timeout in ms; the query is interrupted when exceeded (0 = disabled).
QUERY_TIMEOUT_MS=30000

# Allowed SPA origin during development (Vite dev server).
CORS_ORIGIN=http://localhost:5173

# Set to the built web/dist directory to serve the SPA from this process.
# WEB_DIST=/app/web

# Optional: seed an admin on first run (when no users exist) for headless deploys.
# Otherwise the first admin is created via the app's setup screen.
# ADMIN_USER=admin
# ADMIN_PASSWORD=change-me-please

# Set in production so session cookies are marked Secure (HTTPS only).
# NODE_ENV=production
