# Server configuration (copy to .env or set in the environment)
PORT=3001
HOST=0.0.0.0

# Where the DuckDB file, SQLite metadata DB, and staged uploads live.
DATA_DIR=./data
STAGING_DIR=./data/staging

# Max rows any single metric query may return.
MAX_ROWS=50000

# Allowed SPA origin during development (Vite dev server).
CORS_ORIGIN=http://localhost:5173

# Set to the built web/dist directory to serve the SPA from this process.
# WEB_DIST=/app/web
