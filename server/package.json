{
  "name": "rpt-dash-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DuckDB-backed reporting dashboard API server",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "test": "node --test --import tsx"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
